# Environment Variables for PLATES.AE
# Copy this file to .env.local for local development
# Set these as Vercel Environment Variables for production

# ─── Turso / libSQL Database ───────────────────────────────────────────────
# Get these from: https://turso.tech → your database → "Connect" tab
DATABASE_URL=libsql://your-db-name-your-org.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# ─── Vercel Blob Storage ────────────────────────────────────────────────────
# Auto-set by Vercel when you add the Blob integration.
# For local dev: copy from Vercel project settings → Storage → your Blob store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx
