<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paintings - PLATES.AE</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-red: #e53935;
            --bg-gray: #e0e0e0;
            --text-dark: #333;
            --white: #ffffff;
        }
        body { font-family: 'Segoe UI', sans-serif; margin: 0; background-color: var(--bg-gray); }
        .logo-container { background: white; padding: 20px 10%; display: flex; justify-content: center; align-items: center; }
        .logo { border: 2px solid var(--primary-red); padding: 5px 15px; font-size: 32px; font-weight: bold; color: var(--primary-red); text-decoration: none; }
        .main-nav { background: var(--primary-red); padding: 15px 10%; display: flex; justify-content: flex-end; }
        .main-nav a { color: white; text-decoration: none; margin-left: 20px; font-size: 14px; }
        .container { max-width: 1200px; margin: 20px auto; padding: 0 20px; }
        .paintings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 15px; }
        .painting-item { background: white; border-radius: 4px; overflow: hidden; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .painting-item img { width: 100%; height: 150px; object-fit: cover; }
        .painting-info { padding: 10px; text-align: center; font-size: 14px; }
    </style>
</head>
<body>
    <div class="logo-container">
        <a href="/" class="logo">PLATES.AE</a>
    </div>
    <nav class="main-nav">
        <a href="/">Home</a>
        <a href="/paintings">Paintings</a>
    </nav>
    <div class="container">
        <h2 style="text-align: center; color: #333; margin-bottom: 30px;">Car Paintings</h2>
        <div class="paintings-grid">
            <% if(templates && templates.length > 0) { %>
                <% templates.forEach(function(tmp) { %>
                    <div class="painting-item">
                        <img src="<%= tmp.media_url %>" alt="Car painting">
                        <div class="painting-info">
                            <span><%= tmp.type %></span>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <p style="text-align: center; grid-column: 1/-1;">No paintings available yet.</p>
            <% } %>
        </div>
    </div>
</body>
</html>
